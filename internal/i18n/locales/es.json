  "docs.badge": {"other": "Documentacion"},
  "docs.title": {"other": "Como usar Inspector"},
  "docs.subtitle": {"other": "Inspector te permite crear endpoints de prueba, inspeccionar solicitudes entrantes en tiempo real y enviar solicitudes HTTP o WebSocket para pruebas de integracion."},
  "docs.quick_start.title": {"other": "Inicio rapido"},
  "docs.quick_start.item1": {"other": "Inicia sesion con tus credenciales."},
  "docs.quick_start.item2": {"other": "Ve a Endpoints y crea un endpoint con Nombre y Slug."},
  "docs.quick_start.item3": {"other": "Copia la URL generada y envia solicitudes desde tu sistema."},
  "docs.quick_start.item4": {"other": "Abre Requests para inspeccionar cada solicitud capturada."},
  "docs.quick_start.item5": {"other": "Usa Dashboard para revisar actividad reciente y estadisticas."},
  "docs.sender.title": {"other": "Herramienta Sender"},
  "docs.sender.item1": {"other": "Usa Sender para probar APIs HTTP sin salir de Inspector."},
  "docs.sender.item2": {"other": "Headers y body se validan como JSON antes de enviar."},
  "docs.sender.item3": {"other": "Cada campo JSON incluye acciones: Validar, Corregir y Ejemplo."},
  "docs.sender.item4": {"other": "El historial guarda solicitudes enviadas para reintentos."},
  "docs.sender.item5": {"other": "WS Client te ayuda a conectar y probar servicios WebSocket."},
  "docs.examples.title": {"other": "Ejemplos utiles"},
  "docs.examples.webhook": {"other": "Enviar un webhook con curl:"},
  "docs.examples.ws": {"other": "Conectar a un endpoint WebSocket:"},
  "docs.best_practices.title": {"other": "Buenas practicas"},
  "docs.best_practices.item1": {"other": "Usa slugs descriptivos por entorno, por ejemplo payments-staging."},
  "docs.best_practices.item2": {"other": "Limpia logs desde Endpoints cuando necesites sesiones de prueba mas limpias."},
  "docs.best_practices.item3": {"other": "No compartas credenciales de acceso en entornos publicos."},
  "docs.best_practices.item4": {"other": "Si usas HTTPS con certificados de desarrollo, verifica la configuracion TLS del servicio destino."},
  "docs.mock_rules.title": {"other": "Mock Rules - respuestas condicionales por endpoint"},
  "docs.mock_rules.description": {"other": "Mock Rules permite que el mismo endpoint devuelva respuestas distintas segun la solicitud entrante: metodo HTTP, path, query params, headers o body. Similar a Beeceptor o Mockoon, cada endpoint puede tener multiples reglas; gana la primera que haga match (prioridad ascendente). Si ninguna coincide, se usa como fallback la respuesta estatica del endpoint."},
  "docs.mock_rules.create.title": {"other": "Como crear una regla"},
  "docs.mock_rules.create.item1": {"other": "Ve a Endpoints y abre cualquier endpoint."},
  "docs.mock_rules.create.item2": {"other": "Veras el panel Mock Rules al final de la tarjeta."},
  "docs.mock_rules.create.item3": {"other": "Completa el formulario New Mock Rule y haz clic en Create Mock Rule."},
  "docs.mock_rules.create.item4": {"other": "La regla aparece de inmediato en la lista y queda activa por defecto."},
  "docs.mock_rules.create.item5": {"other": "Puedes editarla en linea y guardar con Save Rule."},
  "docs.mock_rules.fields.title": {"other": "Campos clave"},
  "docs.mock_rules.fields.item1": {"other": "Priority: numero menor se evalua primero. Usa 1, 10, 100..."},
  "docs.mock_rules.fields.item2": {"other": "Method: GET, POST, ANY (o vacio para cualquiera)."},
  "docs.mock_rules.fields.item3": {"other": "Path mode: any, exact, prefix, regex."},
  "docs.mock_rules.fields.item4": {"other": "Body mode: any, exact, contains, regex, json (coincidencia por subconjunto de campos)."},
  "docs.mock_rules.fields.item5": {"other": "Delay ms: retraso antes de responder (util para simular latencia)."},
  "docs.mock_rules.fields.item6": {"other": "Active: toggle rapido sin eliminar la regla."},
  "docs.mock_rules.examples.ex1.title": {"other": "Ejemplo: 200 para GET, 404 para todo lo demas"},
  "docs.mock_rules.examples.ex1.rule_label": {"other": "Regla 1 (prioridad 1):"},
  "docs.mock_rules.examples.ex1.fallback_label": {"other": "Fallback del endpoint:"},
  "docs.mock_rules.examples.ex2.title": {"other": "Ejemplo: respuesta segun JSON del body"},
  "docs.mock_rules.examples.ex3.title": {"other": "Ejemplo: simular timeout"},
  "docs.mock_rules.warning": {"other": "El orden de evaluacion es Priority ASC. Si dos reglas comparten la misma prioridad, gana la de menor ID (regla mas antigua). El fallback final siempre es la respuesta configurada del endpoint."}
}
